---
interface Props {
    icon: string;
    title: string;
    summary: string;
}

const { icon, title, summary } = Astro.props;
---

<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition-shadow">
    <div class="flex justify-center mb-4 text-brand-steel">
        <Fragment set:html={icon} />
    </div>
    <h3 class="text-lg font-display font-bold text-brand-navy mb-2">{title}</h3>
    <p class="text-gray-600 text-sm leading-relaxed">{summary}</p>
</div>
