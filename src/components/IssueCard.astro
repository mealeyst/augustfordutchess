---
interface Props {
    title: string;
    summary: string;
}

const { title, summary } = Astro.props;
---

<div class="bg-white rounded-2xl p-6 shadow-sm border-t-4 border-brand-steel hover:shadow-md transition-shadow">
    <h3 class="font-display font-bold text-brand-navy text-base mb-3">{title}</h3>
    <p class="text-gray-600 text-sm leading-relaxed font-body">{summary}</p>
</div>
