---
const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-navy text-blue-100 mt-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- Brand -->
            <div>
                <img
                    src="/images/logo.png"
                    alt="August Uribe for Dutchess County Legislature"
                    width="160"
                    height="160"
                    class="h-40 w-auto rounded-2xl"
                />
            </div>

            <!-- Quick Links -->
            <div>
                <h3 class="text-white font-display font-semibold mb-3 text-base uppercase tracking-wide">
                    Quick Links
                </h3>
                <ul class="space-y-2 text-base">
                    <li><a href="/meet" class="hover:text-white transition-colors">Meet August</a></li>
                    <li><a href="/issues" class="hover:text-white transition-colors">The Issues</a></li>
                    <li>
                        <a href="/get-involved" class="hover:text-white transition-colors">Get Involved</a>
                    </li>
                    <li>
                        <a href="/contact" class="hover:text-white transition-colors">Contact</a>
                    </li>
                </ul>
            </div>

            <!-- Connect -->
            <div>
                <h3 class="text-white font-display font-semibold mb-3 text-base uppercase tracking-wide">
                    Connect
                </h3>
                <ul class="space-y-2 text-base">
                    <li>
                        <a href="/contact" class="hover:text-white transition-colors">
                            Send a Message
                        </a>
                    </li>
                    <li>
                        <span class="text-blue-400 italic text-xs">
                            Social media coming soon — Facebook & Instagram
                        </span>
                    </li>
                </ul>
            </div>
        </div>

        <div class="mt-10 pt-6 border-t border-white/10 text-xs text-blue-300 flex flex-col sm:flex-row justify-between gap-2">
            <p>
                Paid for by the Friends of August Uribe for Dutchess County Legislature, Dover & Pawling.
            </p>
            <p>&copy; {currentYear} August Uribe for Dutchess County</p>
        </div>
    </div>
</footer>
