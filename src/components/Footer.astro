---
const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-navy text-blue-100 mt-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- Brand -->
            <div>
                <div class="flex items-center gap-3 mb-3">
                    <div
                        class="w-10 h-10 rounded-full bg-brand-cranberry flex items-center justify-center text-white font-display font-bold text-sm"
                    >
                        AU
                    </div>
                    <div>
                        <div class="font-display font-bold text-white">August Uribe</div>
                        <div class="text-xs text-blue-300">Dutchess County Legislator · District 24</div>
                    </div>
                </div>
                <p class="text-sm text-blue-200 leading-relaxed">
                    Fighting for working families and a more equitable Hudson Valley.
                </p>
            </div>

            <!-- Quick Links -->
            <div>
                <h3 class="text-white font-display font-semibold mb-3 text-sm uppercase tracking-wide">
                    Quick Links
                </h3>
                <ul class="space-y-2 text-sm">
                    <li><a href="/about" class="hover:text-white transition-colors">About August</a></li>
                    <li><a href="/issues" class="hover:text-white transition-colors">The Issues</a></li>
                    <li>
                        <a href="/get-involved" class="hover:text-white transition-colors">Get Involved</a>
                    </li>
                    <li>
                        <a href="/contact" class="hover:text-white transition-colors">Contact</a>
                    </li>
                </ul>
            </div>

            <!-- Connect -->
            <div>
                <h3 class="text-white font-display font-semibold mb-3 text-sm uppercase tracking-wide">
                    Connect
                </h3>
                <ul class="space-y-2 text-sm">
                    <li>
                        <a href="/contact" class="hover:text-white transition-colors">
                            Send a Message
                        </a>
                    </li>
                    <li>
                        <span class="text-blue-400 italic text-xs">
                            Social media coming soon — Facebook, Instagram &amp; Bluesky
                        </span>
                    </li>
                </ul>
            </div>
        </div>

        <div class="mt-10 pt-6 border-t border-white/10 text-xs text-blue-300 flex flex-col sm:flex-row justify-between gap-2">
            <p>
                Paid for by August Uribe for Dutchess County Legislator, District 24.
            </p>
            <p>&copy; {currentYear} August Uribe for Dutchess County</p>
        </div>
    </div>
</footer>
