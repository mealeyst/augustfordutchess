---
// Google Analytics 4 via Partytown (runs in web worker, non-blocking)
// Set PUBLIC_GA_MEASUREMENT_ID in your .env file to enable analytics
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
---

{
    gaId && (
        <>
            <script
                type="text/partytown"
                src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}
            />
            <script type="text/partytown" define:vars={{ gaId }}>
                window.dataLayer = window.dataLayer || [];
                function gtag() {
                    dataLayer.push(arguments);
                }
                gtag("js", new Date());
                gtag("config", gaId);
            </script>
        </>
    )
}
