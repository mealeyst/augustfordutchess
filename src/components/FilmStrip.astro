---
interface Props {
    images: { src: string; alt: string }[];
}

const { images } = Astro.props;

// Duplicate the frames so the horizontal scroll can loop seamlessly.
const frames = [...images, ...images];
---

<div class="film" role="region" aria-label="Photos of August's campaign signs around Dover & East Pawling">
    <div class="film-perforations film-perforations--top" aria-hidden="true"></div>
    <div class="film-track">
        {
            frames.map((img, i) => (
                <div class="film-frame" aria-hidden={i >= images.length ? "true" : undefined}>
                    <img src={img.src} alt={i >= images.length ? "" : img.alt} loading="lazy" />
                </div>
            ))
        }
    </div>
    <div class="film-perforations film-perforations--bottom" aria-hidden="true"></div>
</div>

<style>
    .film {
        position: relative;
        overflow: hidden;
        background: #14110b;
        padding: 28px 0;
    }

    /* Sprocket holes along the top and bottom edges of the film */
    .film-perforations {
        position: absolute;
        left: 0;
        right: 0;
        height: 28px;
        background-image: repeating-linear-gradient(
            to right,
            transparent 0,
            transparent 12px,
            #d9d4c5 12px,
            #d9d4c5 28px,
            transparent 28px,
            transparent 40px
        );
        background-size: 40px 14px;
        background-position: 0 center;
        background-repeat: repeat-x;
        z-index: 2;
        /* Scroll the sprocket holes leftward in sync with the frames */
        animation: film-perforations-scroll 1.0s linear infinite;
    }

    .film:hover .film-perforations {
        animation-play-state: paused;
    }

    .film-perforations--top {
        top: 0;
    }

    .film-perforations--bottom {
        bottom: 0;
    }

    .film-track {
        display: flex;
        gap: 14px;
        width: max-content;
        padding: 0 7px;
        animation: film-scroll 60s linear infinite;
    }

    .film:hover .film-track {
        animation-play-state: paused;
    }

    .film-frame {
        flex: 0 0 auto;
        height: 280px;
        border: 3px solid #000;
        background: #000;
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.08);
    }

    .film-frame img {
        height: 100%;
        width: auto;
        display: block;
        object-fit: cover;
        /* Aged-film look */
    }

    @keyframes film-scroll {
        from {
            transform: translateX(0);
        }
        to {
            /* Half the track = one full set of frames (the duplicate) */
            transform: translateX(-50%);
        }
    }

    @keyframes film-perforations-scroll {
        from {
            background-position: 0 center;
        }
        to {
            /* One full pattern repeat (matches background-size width) */
            background-position: -40px center;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .film-track,
        .film-perforations {
            animation: none;
        }
        .film {
            overflow-x: auto;
        }
    }
</style>
