---
import BaseLayout from "@/layouts/BaseLayout.astro";
import VolunteerForm from "@/components/VolunteerForm";
---

<BaseLayout
    title="Get Involved"
    description="Volunteer, donate, or sign up to support August Uribe for Dutchess County Legislator District 24."
>
    <!-- Page Header -->
    <section class="bg-brand-navy text-white py-20">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
            <h1 class="text-4xl sm:text-5xl font-display font-bold mb-4">Get Involved</h1>
            <p class="text-xl text-blue-200 max-w-2xl mx-auto font-body italic text-left">
                Elections are won one conversation at a time. Join us and help make the difference in
                District 24.
            </p>
        </div>
    </section>

    <!-- Ways to Help -->
    <section class="py-20 bg-brand-light">
        <div class="max-w-6xl mx-auto px-4 sm:px-6">
            <h2 class="text-3xl font-display font-bold text-brand-navy text-center mb-12">
                Ways You Can Help
            </h2>
            <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
                {
                    [
                        {
                            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                            </svg>`,
                            title: "Canvass",
                            desc: "Hit the doors with us! Deep canvassing is the most effective way to reach voters. Training provided. You got this!",
                        },
                        {
                            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                            </svg>`,
                            title: "Phone Bank",
                            desc: "Help us call voters from home or at a hosted event. We'll provide the script, the list, and all the support you need.",
                        },
                        {
                            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>`,
                            title: "Coffee & Conversation",
                            desc: "Host or attend a block party in your neighborhood. These small gatherings are where real connections happen.",
                        },
                        {
                            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
                            </svg>`,
                            title: "Spread the Word",
                            desc: "Share August's message with neighbors, friends, family, and co-workers. Put up a yard sign or help out at local community events.",
                        },
                    ].map((way) => (
                        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 border-t-4 border-t-brand-steel text-center">
                            <div class="flex justify-center mb-4 text-brand-steel">
                                <Fragment set:html={way.icon} />
                            </div>
                            <h3 class="text-xl font-display font-bold text-brand-navy mb-2">{way.title}</h3>
                            <p class="text-gray-600 text-sm leading-relaxed font-body">{way.desc}</p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Volunteer Sign-Up Form -->
    <section id="volunteer" class="py-20 bg-white">
        <div class="max-w-xl mx-auto px-4 sm:px-6">
            <div class="text-center mb-10">
                <h2 class="text-3xl font-display font-bold text-brand-navy mb-4">Sign Up to Volunteer</h2>
                <p class="text-gray-600 font-body">
                    Fill out the form below and a member of the campaign team will be in touch soon.
                </p>
            </div>
            <VolunteerForm client:load />
        </div>
    </section>

    <!-- Donate Section -->
    <section id="donate" class="py-20 bg-brand-navy text-white">
        <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">
            <h2 class="text-3xl font-display font-bold mb-4">Donate to the Campaign</h2>
            <p class="text-blue-200 mb-8 leading-relaxed font-body">
                Campaign contributions help us reach voters, print materials, run ads, and get August's
                message out across District 24. Every dollar helps build the Hudson Valley our families
                deserve.
            </p>

            <!-- Donation amount buttons -->
            <div class="flex flex-wrap gap-3 justify-center mb-8">
                {
                    ["$10", "$25", "$50", "$100", "$250", "Other"].map((amount) => (
                        <a
                            href="#donate-link"
                            class="bg-white/10 hover:bg-white/20 border border-white/30 text-white px-5 py-3 rounded font-display font-semibold transition-colors min-w-[4rem]"
                        >
                            {amount}
                        </a>
                    ))
                }
            </div>

            <a
                id="donate-link"
                href="#"
                class="inline-block bg-brand-steel hover:bg-brand-steel-dark text-white px-8 py-4 rounded font-display font-bold text-xl transition-colors"
            >
                Donate Now
            </a>

            <p class="mt-6 text-xs text-blue-300 font-body">
                Paid for by August Uribe for Dutchess County Legislator, District 24.<br />
                Contributions are subject to New York State campaign finance laws.
                Contributions from corporations, LLCs, and foreign nationals are prohibited.
            </p>
        </div>
    </section>
</BaseLayout>
