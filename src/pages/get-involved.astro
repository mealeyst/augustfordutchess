---
import BaseLayout from "@/layouts/BaseLayout.astro";
import VolunteerForm from "@/components/VolunteerForm";
---

<BaseLayout
    title="Get Involved"
    description="Volunteer, donate, or sign up to support August Uribe for Dutchess County Legislator Dover & Pawling."
>
    <!-- Page Header -->
    <section class="relative bg-brand-navy text-white py-20">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
            <h1 class="text-4xl sm:text-5xl font-display font-bold mb-4">GET INVOLVED</h1>
            <p class="text-xl text-blue-200 max-w-2xl mx-auto font-body italic text-left">
                Elections are won one conversation at a time. There is a volunteer opportunity for
                everyone to make the difference in
                Dover & Pawling.
            </p>
        </div>
    </section>

    <!-- Volunteer + Donate (side by side) -->
    <section class="py-20 bg-white">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 grid lg:grid-cols-2 gap-10 items-start">
            <!-- Sign Up to Volunteer (left) -->
            <div id="volunteer">
                <div class="mb-8">
                    <h2 class="text-3xl font-display font-bold text-brand-navy mb-4">Sign Up to Volunteer</h2>
                    <p class="text-gray-600 font-body">
                        Fill out the form below and a member of the campaign team will be in touch soon.
                    </p>
                </div>
                <VolunteerForm client:load />
            </div>

            <!-- Donate to the Campaign (right) -->
            <div id="donate" class="bg-brand-navy text-white rounded-2xl p-8 sm:p-10 text-center">
                <h2 class="text-3xl font-display font-bold mb-4">Donate to the Campaign</h2>
                <p class="text-blue-200 mb-8 leading-relaxed font-body">
                    Campaign contributions help us reach voters, print materials, run ads, and get August's
                    message out across Dover & Pawling. Every dollar helps build the Hudson Valley our families
                    deserve.
                </p>

                <!-- Donation amount buttons -->
                <div class="flex flex-wrap gap-3 justify-center mb-8">
                    {
                        [
                            { label: "$25", amount: "25" },
                            { label: "$50", amount: "50" },
                            { label: "$100", amount: "100" },
                            { label: "$250", amount: "250" },
                            { label: "Other", amount: null },
                        ].map(({ label, amount }) => {
                            const refcode = amount ? `getinvolved_${amount}` : "getinvolved_other";
                            const params = new URLSearchParams();
                            if (amount) params.set("amount", amount);
                            params.set("refcode", refcode);
                            const href = `https://secure.actblue.com/donate/august-uribe-1?${params.toString()}`;
                            return (
                                <a
                                    href={href}
                                    class="bg-white/10 hover:bg-white/20 border border-white/30 text-white px-5 py-3 rounded font-display font-semibold transition-colors min-w-[4rem]"
                                >
                                    {label}
                                </a>
                            );
                        })
                    }
                </div>

                <a
                    href="https://secure.actblue.com/donate/august-uribe-1?refcode=getinvolved_main"
                    class="inline-block bg-brand-money hover:bg-brand-money-dark text-white px-8 py-4 rounded font-display font-bold text-xl transition-colors"
                >
                    Donate Now
                </a>

                <p class="mt-6 text-xs text-blue-300 font-body">
                    Paid for by August Uribe for Dutchess County Legislator, Dover & Pawling.<br />
                    Contributions are subject to New York State campaign finance laws.
                    Contributions from corporations, LLCs, and foreign nationals are prohibited.
                </p>
            </div>
        </div>
    </section>

    <!-- Ways to Help -->
    <section class="py-20 bg-brand-light">
        <div class="max-w-6xl mx-auto px-4 sm:px-6">
            <h2 class="text-3xl font-display font-bold text-brand-navy text-center mb-12">
                Ways You Can Help
            </h2>
            <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-6">
                {
                    [
                        {
                            title: "Coffee & Conversation",
                            desc: "Host or attend a block party in your neighborhood. Small gatherings are where real connections happen.",
                        },
                        {
                            title: "Spread the Word",
                            desc: "Share August's message with neighbors, friends, family, and co-workers. Put up a yard sign or help out at local community events.",
                        },
                        {
                            title: "Phone Bank",
                            desc: "Help us call voters from home or at a hosted event. We'll provide the script, the list, and all the support you need.",
                        },
                        {
                            title: "Canvass",
                            desc: "Going out and canvassing is the most effective way to reach voters. Training is provided, you got this!",
                        },
                        {
                            title: "Donate",
                            desc: 'Please "click" on the green button above.',
                        },
                    ].map((way) => (
                        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 border-t-4 border-t-brand-steel text-center">
                            <h3 class="text-xl font-display font-bold text-brand-navy mb-2">{way.title}</h3>
                            <p class="text-gray-600 text-sm leading-relaxed font-body text-left">{way.desc}</p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>
</BaseLayout>
