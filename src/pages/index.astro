---
import GoogleAnalytics from "@/components/GoogleAnalytics.astro";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta
            name="description"
            content="August Uribe for Dutchess County Legislator — District 24. Coming soon."
        />
        <meta name="robots" content="noindex, nofollow" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&family=Lora:ital,wght@0,400;0,600;1,400&display=swap"
            rel="stylesheet"
        />
        <title>August Uribe for Dutchess County Legislator — District 24</title>
        <GoogleAnalytics />
        <style>
            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }
            html,
            body {
                height: 100%;
            }
            body {
                background-color: #0f172a;
                color: white;
                font-family: "Lora", serif;
                display: flex;
                align-items: center;
                justify-content: center;
                min-height: 100vh;
                padding: 2rem;
            }
            .dot-grid {
                position: fixed;
                inset: 0;
                opacity: 0.08;
                background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0);
                background-size: 40px 40px;
                pointer-events: none;
            }
            .container {
                position: relative;
                text-align: center;
                max-width: 640px;
                width: 100%;
            }
            .badge {
                display: inline-block;
                background: rgba(79, 127, 161, 0.2);
                border: 1px solid rgba(79, 127, 161, 0.4);
                color: #9fc3d9;
                font-family: "Outfit", sans-serif;
                font-weight: 600;
                font-size: 1.1rem;
                letter-spacing: 0.05em;
                text-transform: uppercase;
                padding: 0.35rem 1rem;
                border-radius: 9999px;
                margin-bottom: 2rem;
            }
            .name {
                font-family: "Outfit", sans-serif;
                font-weight: 800;
                font-size: clamp(2.5rem, 8vw, 4.5rem);
                line-height: 1.05;
                margin-bottom: 0.5rem;
                letter-spacing: -0.02em;
            }
            .name span {
                color: #d4af37;
            }
            .district {
                font-family: "Outfit", sans-serif;
                font-weight: 300;
                font-size: 1.1rem;
                color: #93a8c4;
                margin-bottom: 2.5rem;
                letter-spacing: 0.02em;
            }
            .divider {
                width: 3rem;
                height: 3px;
                background: #4F7FA1;
                margin: 0 auto 2.5rem;
                border-radius: 2px;
            }
            .coming-soon {
                font-family: "Outfit", sans-serif;
                font-weight: 700;
                font-size: clamp(1.2rem, 3vw, 1.6rem);
                letter-spacing: 0.18em;
                text-transform: uppercase;
                color: #d4af37;
                margin-bottom: 1.25rem;
            }
            .tagline {
                font-size: 1.1rem;
                color: #93a8c4;
                line-height: 1.7;
                font-style: italic;
            }
        </style>
    </head>
    <body>
        <div class="dot-grid"></div>
        <div class="container">
            <div class="badge">Democrat &middot; Dutchess County Legislator &middot; District 24</div>
            <h1 class="name">
                August <span>Uribe</span>
            </h1>
            <p class="district">for Dutchess County</p>
            <div class="divider"></div>
            <p class="coming-soon">Coming Soon</p>
            <p class="tagline">
                For Our Home. For Our Future. For All of Us.
            </p>
        </div>
    </body>
</html>
