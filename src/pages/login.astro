---
import GoogleAnalytics from "@/components/GoogleAnalytics.astro";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="robots" content="noindex, nofollow" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&family=Lora:ital,wght@0,400;0,600;1,400&display=swap"
            rel="stylesheet"
        />
        <title>Login — August Uribe for Dutchess County</title>
        <GoogleAnalytics />
        <style>
            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }
            html,
            body {
                height: 100%;
            }
            body {
                background-color: #0f172a;
                color: white;
                font-family: "Outfit", sans-serif;
                display: flex;
                align-items: center;
                justify-content: center;
                min-height: 100vh;
                padding: 2rem;
            }
            .dot-grid {
                position: fixed;
                inset: 0;
                opacity: 0.08;
                background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0);
                background-size: 40px 40px;
                pointer-events: none;
            }
            .card {
                position: relative;
                background: #1e293b;
                border: 1px solid rgba(255, 255, 255, 0.08);
                border-radius: 1rem;
                padding: 2.5rem;
                width: 100%;
                max-width: 400px;
            }
            .wordmark {
                text-align: center;
                margin-bottom: 2rem;
            }
            .wordmark h1 {
                font-size: 1.5rem;
                font-weight: 800;
                letter-spacing: -0.02em;
            }
            .wordmark h1 span {
                color: #d4af37;
            }
            .wordmark p {
                font-size: 0.8rem;
                color: #64748b;
                margin-top: 0.25rem;
                letter-spacing: 0.04em;
                text-transform: uppercase;
            }
            .divider {
                width: 2rem;
                height: 2px;
                background: #9b1b30;
                margin: 0 auto 2rem;
                border-radius: 2px;
            }
            label {
                display: block;
                font-size: 0.8rem;
                font-weight: 600;
                color: #94a3b8;
                letter-spacing: 0.05em;
                text-transform: uppercase;
                margin-bottom: 0.4rem;
            }
            input {
                width: 100%;
                background: #0f172a;
                border: 1px solid rgba(255, 255, 255, 0.1);
                border-radius: 0.5rem;
                color: white;
                font-family: "Outfit", sans-serif;
                font-size: 1rem;
                padding: 0.65rem 0.85rem;
                margin-bottom: 1.25rem;
                outline: none;
                transition: border-color 0.15s;
            }
            input:focus {
                border-color: #d4af37;
            }
            button {
                width: 100%;
                background: #9b1b30;
                color: white;
                font-family: "Outfit", sans-serif;
                font-size: 1rem;
                font-weight: 700;
                padding: 0.75rem;
                border: none;
                border-radius: 0.5rem;
                cursor: pointer;
                transition: background 0.15s;
                margin-top: 0.25rem;
            }
            button:hover {
                background: #7f1626;
            }
            .error {
                display: none;
                background: rgba(155, 27, 48, 0.15);
                border: 1px solid rgba(155, 27, 48, 0.4);
                color: #e87c8d;
                font-size: 0.875rem;
                padding: 0.6rem 0.85rem;
                border-radius: 0.5rem;
                margin-bottom: 1rem;
            }
        </style>
    </head>
    <body>
        <div class="dot-grid"></div>
        <div class="card">
            <div class="wordmark">
                <h1>August <span>Uribe</span></h1>
                <p>Dutchess County · District 24</p>
            </div>
            <div class="divider"></div>
            <form id="login-form">
                <p class="error" id="error">Invalid username or password.</p>
                <label for="username">Username</label>
                <input type="text" id="username" name="username" autocomplete="username" />
                <label for="password">Password</label>
                <input type="password" id="password" name="password" autocomplete="current-password" />
                <button type="submit">Sign In</button>
            </form>
        </div>

        <script>
            (function () {
                function getCookie(name) {
                    var match = document.cookie.match(new RegExp("(^| )" + name + "=([^;]+)"));
                    return match ? match[2] : null;
                }
                if (getCookie("site_auth")) {
                    window.location.replace("/about");
                }
            })();

            document.getElementById("login-form").addEventListener("submit", function (e) {
                e.preventDefault();
                var username = document.getElementById("username").value.trim();
                var password = document.getElementById("password").value;
                var error = document.getElementById("error");
                if (username === "august" && password === "Dutch3ssD3ms") {
                    var maxAge = 60 * 60 * 24 * 30;
                    document.cookie = "site_auth=1; path=/; max-age=" + maxAge;
                    window.location.href = "/about";
                } else {
                    error.style.display = "block";
                }
            });
        </script>
    </body>
</html>
