---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlockQuote from "@/components/BlockQuote.astro";
import IssueCard from "@/components/IssueCard.astro";

const issues = [
    {
        title: "Economic Dignity",
        summary:
            "Advocating for wages that reflect the Hudson Valley's cost of living, smart zoning, and rent protections so every working family can afford to stay.",
    },
    {
        title: "Investing in Education",
        summary:
            "Maximizing county support for school mental health, championing vocational partnerships, and treating education as long-term economic development.",
    },
    {
        title: "Modernizing Infrastructure",
        summary:
            "Securing grants for roads and bridges, expanding public transit, and treating high-speed broadband as a necessary utility — not a luxury.",
    },
];
---

<BaseLayout title="Home">
    <!-- Hero Section -->
    <section
        class="relative bg-brand-navy text-white overflow-hidden"
        style="min-height: 90vh; display: flex; align-items: center;"
    >
        <div
            class="absolute inset-0 opacity-10"
            style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 40px 40px;"
        >
        </div>

        <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-24 grid md:grid-cols-2 gap-12 items-center">
            <!-- Photo side -->
            <div class="flex justify-center">
                <img
                    src="/images/2026.04.CN.6890.jpg"
                    alt="August Uribe, candidate for Dutchess County Legislator Dover & East Pawling"
                    class="w-48 sm:w-52 rounded-2xl shadow-2xl object-cover border-4 border-brand-steel/30"
                />
            </div>
            <!-- Text side -->
            <div>
                <div
                    class="inline-block bg-brand-steel/20 border border-brand-steel/40 text-brand-sky font-display font-semibold text-xl px-5 py-3 rounded-2xl mb-6 leading-snug"
                >
                    Democratic Candidate<br />
                    Dutchess County Legislator<br />
                    Dover & East Pawling
                </div>
                <p class="text-brand-gold font-display font-semibold text-2xl sm:text-3xl mb-2">Welcome to</p>
                <h1 class="text-3xl sm:text-4xl lg:text-5xl font-display font-bold leading-tight mb-4">
                    August Uribe's<br />Campaign
                </h1>
                <p class="text-2xl sm:text-3xl font-body italic text-brand-steel leading-snug mb-8">
                    For Our Home. For Our Future.<br />For All of Us.
                </p>
                <div class="flex flex-wrap gap-4">
                    <a
                        href="/get-involved"
                        class="bg-brand-steel hover:bg-brand-steel-dark text-white px-6 py-3 rounded font-display font-semibold text-lg transition-colors"
                    >
                        Get Involved
                    </a>
                    <a
                        href="/meet"
                        class="border-2 border-white text-white hover:bg-white hover:text-brand-navy px-6 py-3 rounded font-display font-semibold text-lg transition-colors"
                    >
                        Meet August
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Issues Preview -->
    <section class="py-20 bg-brand-light">
        <div class="max-w-6xl mx-auto px-4 sm:px-6">
            <div class="mb-12">
                <h2 class="text-3xl sm:text-4xl font-display font-bold text-brand-navy mb-4 text-center">
                    A Platform Built for Dover & East Pawling
                </h2>
                <p class="text-gray-600 text-lg max-w-2xl mx-auto">
                    August is focused on the issues that directly impact families in our community —
                    economic dignity, education, and the infrastructure we all depend on.
                </p>
            </div>
            <div class="grid sm:grid-cols-3 gap-6">
                {issues.map((issue) => <IssueCard {...issue} />)}
            </div>
            <div class="text-center mt-10">
                <a
                    href="/issues"
                    class="inline-block bg-brand-navy hover:bg-brand-navy-mid text-white px-6 py-3 rounded font-display font-semibold transition-colors"
                >
                    See Full Platform
                </a>
            </div>
        </div>
    </section>

    <BlockQuote
        attribution="August Uribe"
    >
        As your legislator, I will be your direct line to our seat in Dutchess County looking out for your needs in our district.
    </BlockQuote>

    <!-- What a County Legislator Does -->
    <section class="py-20 bg-brand-light">
        <div class="max-w-4xl mx-auto px-4 sm:px-6">
            <div class="text-center mb-10">
                <h2 class="text-3xl sm:text-4xl font-display font-bold text-brand-navy mb-4">
                    What Does a County Legislator Do?
                </h2>
                <p class="text-gray-600 font-body text-lg italic">
                    Your county legislator is your direct voice in Poughkeepsie.
                </p>
            </div>
            <div class="grid sm:grid-cols-2 gap-4">
                {[
                    "Votes on the county budget and how taxpayer money is spent",
                    "Passes local laws and resolutions at the county level",
                    "Helps decide funding for roads, public safety, health services, parks, and senior services",
                    "Reviews contracts, major projects, and department spending",
                    "Represents the concerns and needs of the people in their district",
                    "Works with county officials to address local problems and plan for the future",
                ].map((item) => (
                    <div class="bg-white rounded-2xl p-6 shadow-sm border-t-4 border-brand-steel">
                        <p class="text-gray-700 font-body leading-relaxed">{item}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Why This Election Matters -->
    <section class="py-20 bg-white">
        <div class="max-w-3xl mx-auto px-4 sm:px-6">
            <h2 class="text-3xl sm:text-4xl font-display font-bold text-brand-navy mb-6 text-center">
                Why This Election Matters
            </h2>
            <p class="text-gray-700 font-body text-lg leading-relaxed mb-6">
                Local elections decide how your tax dollars are spent, whether your roads get fixed, and whether your family has access to the services you count on. Yet they are often decided by the smallest margins — sometimes just a handful of votes.
            </p>
            <p class="text-gray-700 font-body text-lg leading-relaxed">
                Dover & East Pawling deserves a legislator who shows up, listens, and fights for our community every single day. That is exactly what August is committed to doing. Your vote — and your voice — can make the difference.
            </p>
        </div>
    </section>

    <!-- Get Involved CTA -->
    <section class="py-20 bg-brand-steel text-white">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
            <h2 class="text-3xl sm:text-4xl font-display font-bold mb-4">Join the Campaign</h2>
            <p class="text-lg text-blue-100 mb-8 max-w-xl mx-auto">
                Volunteer, donate, or spread the word. Together we can build the Dutchess County our
                families deserve.
            </p>
            <div class="flex flex-wrap gap-4 justify-center">
                <a
                    href="/get-involved#volunteer"
                    class="bg-white text-brand-steel hover:bg-blue-50 px-6 py-3 rounded font-display font-semibold text-lg transition-colors"
                >
                    Volunteer
                </a>
                <a
                    href="/get-involved#donate"
                    class="border-2 border-white text-white hover:bg-white hover:text-brand-steel px-6 py-3 rounded font-display font-semibold text-lg transition-colors"
                >
                    Donate
                </a>
            </div>
        </div>
    </section>
</BaseLayout>