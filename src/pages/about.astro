---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
    title="About August"
    description="Learn about August Uribe, candidate for Dutchess County Legislator District 24 — his background, values, and vision for the community."
>
    <!-- Page Header -->
    <section class="bg-brand-navy text-white py-20">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
            <h1 class="text-4xl sm:text-5xl font-display font-bold mb-4">About August Uribe</h1>
            <p class="text-xl text-blue-200 max-w-2xl mx-auto font-body italic">
                Steady, accountable leadership rooted in fiscal responsibility, fairness, and transparency.
            </p>
        </div>
    </section>

    <!-- Bio Section -->
    <section class="py-20 bg-white">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 grid md:grid-cols-2 gap-12 items-start">
            <!-- Candidate photo -->
            <div class="flex justify-center md:sticky md:top-24">
                <img
                    src="/images/2026.04.CN.6890.jpg"
                    alt="August Uribe, candidate for Dutchess County Legislator District 24"
                    class="w-72 rounded-2xl shadow-lg object-cover border border-gray-200"
                />
            </div>

            <!-- Bio Content -->
            <div>
                <h2 class="text-3xl font-display font-bold text-brand-navy mb-6">
                    Committed to District 24
                </h2>
                <div class="space-y-4 text-gray-700 leading-relaxed font-body">
                    <p>
                        August Uribe is committed to serving the residents of Dutchess County with steady,
                        accountable leadership rooted in fiscal responsibility, fairness, and transparency.
                        He believes local government should work for the people it represents, uphold equal
                        treatment under the law, and operate within clear constitutional boundaries.
                    </p>
                    <p>
                        Uribe values independence and personal freedom, approaches government expansion with
                        caution, and will be a strong advocate for civil liberties and the rights of all
                        residents. The son of a United States career diplomat with postings throughout the
                        Americas, August is a college graduate who majored in Politics and is fluent in
                        Spanish and Portuguese.
                    </p>
                    <p>
                        As a licensed auctioneer for more than 25 years, August has helped raise over $20
                        million for schools, medical institutions, and social service organizations. He has
                        served on the Board of Directors of several nonprofit institutions, including the
                        Archives of American Art at the Smithsonian Institution.
                    </p>
                    <p>
                        August has authorized contracts, managed and reviewed annual budgets, allocated
                        staff funding, and ensured compliance with local regulations. He oversaw major
                        capital improvements — including roof, elevator, boiler, plumbing, and sidewalk
                        projects — while staying on budget and anticipating long-term needs.
                    </p>
                    <p>
                        August Uribe and his wife Lisbeth, an elementary school teacher, and their two
                        adult sons are deeply committed to supporting the needs of Dutchess County,
                        specifically the communities of District 24.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats -->
    <section class="py-16 bg-brand-light">
        <div class="max-w-5xl mx-auto px-4 sm:px-6">
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
                {
                    [
                        { stat: "25+", label: "Years as Licensed Auctioneer" },
                        { stat: "$20M+", label: "Raised for Community Organizations" },
                        { stat: "3", label: "Languages — English, Spanish & Portuguese" },
                        { stat: "Smithsonian", label: "Board Member, Archives of American Art" },
                    ].map((item) => (
                        <div class="bg-white rounded-xl p-5 text-center shadow-sm border border-gray-100">
                            <div class="text-xl font-display font-bold text-brand-cranberry mb-1">
                                {item.stat}
                            </div>
                            <div class="text-xs text-gray-500 leading-snug font-body">{item.label}</div>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Values Section -->
    <section class="py-20 bg-white">
        <div class="max-w-5xl mx-auto px-4 sm:px-6">
            <div class="text-center mb-12">
                <h2 class="text-3xl sm:text-4xl font-display font-bold text-brand-navy mb-4">
                    August's Values
                </h2>
                <p class="text-gray-600 text-lg font-body italic">What guides every decision he makes.</p>
            </div>
            <div class="grid sm:grid-cols-3 gap-6">
                {
                    [
                        {
                            title: "Fiscal Responsibility",
                            desc: "August believes taxpayer dollars must be spent wisely. He will eliminate wasteful spending, enforce fiscal discipline, and ensure the county budget reflects the actual needs of its residents.",
                        },
                        {
                            title: "Fairness & Transparency",
                            desc: "Every resident deserves equal treatment under the law. August will operate with full transparency — making decisions openly and being accountable to the community he serves.",
                        },
                        {
                            title: "Civil Liberties",
                            desc: "August values independence and personal freedom. He approaches government expansion with caution and will be a steadfast advocate for the rights and civil liberties of all District 24 residents.",
                        },
                    ].map((value) => (
                        <div class="bg-brand-light rounded-xl p-6 border-t-4 border-brand-gold text-center">
                            <h3 class="text-xl font-display font-bold text-brand-navy mb-3">
                                {value.title}
                            </h3>
                            <p class="text-gray-600 text-sm leading-relaxed font-body">{value.desc}</p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Quote -->
    <section class="py-20 bg-brand-navy text-white">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
            <div class="text-brand-gold text-5xl mb-6 font-body">&ldquo;</div>
            <blockquote class="text-xl sm:text-2xl font-body italic text-blue-100 leading-relaxed mb-6">
                Public service means sound judgment, fiscal responsibility, and a steadfast commitment to
                the community.
            </blockquote>
            <p class="text-blue-300 font-display font-semibold">— August Uribe</p>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-16 bg-brand-light text-brand-navy text-center">
        <div class="max-w-2xl mx-auto px-4 sm:px-6">
            <h2 class="text-2xl font-display font-bold mb-4">Ready to support August?</h2>
            <p class="text-gray-600 mb-6 font-body">
                Every conversation, every door knocked, and every dollar donated moves us forward.
            </p>
            <div class="flex flex-wrap gap-4 justify-center">
                <a
                    href="/get-involved"
                    class="bg-brand-navy text-white hover:bg-brand-navy-mid px-6 py-3 rounded font-display font-semibold transition-colors"
                >
                    Get Involved
                </a>
                <a
                    href="/contact"
                    class="border-2 border-brand-navy text-brand-navy hover:bg-brand-navy hover:text-white px-6 py-3 rounded font-display font-semibold transition-colors"
                >
                    Contact August
                </a>
            </div>
        </div>
    </section>
</BaseLayout>
