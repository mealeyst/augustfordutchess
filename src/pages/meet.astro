---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlockQuote from "@/components/BlockQuote.astro";
---

<BaseLayout
    title="About August"
    description="Learn about August Uribe, candidate for Dutchess County Legislator District 24 — his background, values, and vision for the community."
>
    <!-- Page Header -->
    <section class="bg-brand-navy text-white py-20">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
            <h1 class="text-4xl sm:text-5xl font-display font-bold mb-4">Meet August Uribe</h1>
            <p class="text-xl text-blue-200 max-w-2xl mx-auto font-body italic"><span class="block">Steady, accountable leadership rooted in</span><span class="block">fiscal responsibility, fairness, and transparency.</span></p>
        </div>
    </section>

    <!-- Bio Section -->
    <section class="py-20 bg-white">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 grid md:grid-cols-2 gap-12 items-start">
            <!-- Candidate photo -->
            <div class="flex justify-center md:sticky md:top-24">
                <img
                    src="/images/2026.04.CN.6890.jpg"
                    alt="August Uribe, candidate for Dutchess County Legislator District 24"
                    class="w-80 rounded-2xl shadow-lg object-cover border border-gray-200"
                />
            </div>

            <!-- Bio Content -->
            <div>
                <h2 class="text-3xl font-display font-bold text-brand-navy mb-6">
                    A Legislator That Will Be Committed to District 24
                </h2>
                <div class="space-y-4 text-slate-600 leading-relaxed font-body">
                    <p>
                        August Uribe is committed to serving the residents of Dutchess County with steady,
                        accountable leadership grounded in fiscal responsibility, fairness, and transparency.
                        He believes local government should serve the people it represents, uphold equal
                        treatment under the law, and operate within clear constitutional limits.
                    </p>
                    <p>
                        He values independence and personal freedom, approaches government growth with
                        caution, and will be a strong advocate for civil liberties and the rights of all
                        residents. The son of a United States career diplomat who served throughout the
                        Americas, August earned a degree in Politics and is fluent in Spanish and Portuguese.
                    </p>
                    <p>
                        For more than 25 years, August has worked as a licensed auctioneer and has helped
                        raise over $20 million for schools, medical institutions, and social service
                        organizations. He has also served on the boards of several nonprofit institutions,
                        including the Archives of American Art at the Smithsonian Institution.
                    </p>
                    <p>
                        His professional experience has given him a strong foundation in budgeting, contract
                        review, long term planning, and project oversight. He understands how to balance
                        priorities, manage resources responsibly, and make practical decisions in the public
                        interest — skills that would serve Pawling and Dover well in the County Legislature.
                    </p>
                    <p>
                        August and his wife, Lisbeth, an elementary school teacher, along with their two
                        adult sons, are deeply committed to supporting the needs of Dutchess County and the
                        communities of District 24.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats -->
    <section class="py-16 bg-brand-light">
        <div class="max-w-5xl mx-auto px-4 sm:px-6">
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-6">
                {
                    [
                        { stat: "25+", label: "Years as Licensed Auctioneer" },
                        { stat: "$20M+", label: "Raised for Community Organizations" },
                        { stat: "3", label: "Languages — English, Spanish & Portuguese" },
                    ].map((item) => (
                        <div class="bg-white rounded-xl p-5 text-center shadow-sm border border-gray-100 border-t-4 border-t-brand-gold">
                            <div class="text-3xl font-display font-bold text-brand-steel mb-1">
                                {item.stat}
                            </div>
                            <div class="text-sm text-gray-600 leading-snug font-body">{item.label}</div>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Values Section -->
    <section class="py-20 bg-white">
        <div class="max-w-5xl mx-auto px-4 sm:px-6">
            <div class="text-center mb-12">
                <h2 class="text-3xl sm:text-4xl font-display font-bold text-brand-navy mb-4 tracking-wide">
                    AUGUST'S VALUES
                </h2>
                <p class="text-gray-600 text-lg font-body italic">What guides every decision he makes.</p>
            </div>
            <div class="grid sm:grid-cols-3 gap-6">
                {
                    [
                        {
                            title: "Fiscal Responsibility",
                            desc: "August believes taxpayer dollars must be spent wisely. He will eliminate wasteful spending, enforce fiscal discipline, and ensure the county budget reflects the actual needs of its residents.",
                        },
                        {
                            title: "Fairness & Transparency",
                            desc: "Every resident deserves equal treatment under the law. August will operate with full transparency — making decisions openly and being accountable to the community he serves.",
                        },
                        {
                            title: "Civil Liberties",
                            desc: "August values independence and personal freedom. He approaches government expansion with caution and will be a steadfast advocate for the rights and civil liberties of all District 24 residents.",
                        },
                    ].map((value) => (
                        <div class="bg-brand-light rounded-xl p-6 border-t-4 border-brand-gold text-center">
                            <h3 class="text-xl font-display font-bold text-brand-navy mb-3 uppercase tracking-wide">
                                {value.title}
                            </h3>
                            <p class="text-gray-600 text-sm leading-relaxed font-body">{value.desc}</p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <BlockQuote
        attribution="August Uribe"
        dark
    >
        Public service means sound judgment, fiscal responsibility, <br />and a steadfast commitment to the community.
    </BlockQuote> 

    <!-- CTA -->
    <section class="py-16 bg-brand-light text-brand-navy">
        <div class="max-w-2xl mx-auto px-4 sm:px-6">
            <h2 class="text-2xl font-display font-bold mb-4 text-center">It's Time for a Democrat in District 24.</h2>
            <p class="text-gray-600 mb-6 font-body">
                August can win this race with a team of dedicated and passionate volunteers like yourself. Every conversation, every door knocked, and every dollar donated moves us forward.
            </p>
            <div class="flex flex-wrap gap-4 justify-center">
                <a
                    href="/get-involved"
                    class="bg-brand-navy text-white hover:bg-brand-navy-mid px-6 py-3 rounded font-display font-semibold transition-colors"
                >
                    GET INVOLVED TODAY
                </a>
                <a
                    href="/contact"
                    class="bg-brand-steel hover:bg-brand-steel-dark text-white px-6 py-3 rounded font-display font-semibold transition-colors"
                >
                    Contact August
                </a>
            </div>
        </div>
    </section>
</BaseLayout>
