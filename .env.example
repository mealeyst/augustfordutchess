# Google Analytics Measurement ID
# Get this from your Google Analytics property settings
# Format: G-XXXXXXXXXX
PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Web3Forms Access Key
# Used by the contact and get-involved forms to deliver submissions via email.
# Get a key from https://web3forms.com (sent to the destination email).
PUBLIC_WEB3FORMS_ACCESS_KEY=00000000-0000-0000-0000-000000000000
